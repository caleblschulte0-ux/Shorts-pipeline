*.py[cod]
*.egg-info/
.venv/
venv/

# Generated artifacts and large media
output/
# Built bottom-strip b-roll (downloaded/normalized clips + stitched output).
# Keep the src/ drop folder + its README; ignore everything generated.
data_learning/broll/clips/
data_learning/broll/_norm/
data_learning/broll/satisfying.mp4
data_learning/broll/.offset
data_learning/broll/src/*
!data_learning/broll/src/README.md
gameplay/*.mp4
gameplay/*.mkv
gameplay/*.webm
gameplay/*.mov
gameplay/*.m4v
gameplay/*.avi

# Whisper model cache
.cache/

# Loose trending-package JSONs are local QA artifacts. The daily routine
# writes its packages into a date-stamped subdir (state/trending_packages/
# YYYYMMDD/) which is what we want to track.
state/trending_packages/*.json

# OAuth secrets — never commit
client_secret.json
token.json
kokoro_models/
.tiktok_secret
.tiktok_redirect_uri
