__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Generated artifacts and large media
output/
# Built bottom-strip b-roll (downloaded/normalized clips + stitched output).
# Keep the src/ drop folder + its README; ignore everything generated.
data_learning/broll/clips/
data_learning/broll/_norm/
data_learning/broll/satisfying.mp4
data_learning/broll/styles/
data_learning/broll/.offset
data_learning/broll/.rotation
data_learning/broll/src/*
!data_learning/broll/src/README.md
gameplay/*.mp4
gameplay/*.mkv
gameplay/*.webm
gameplay/*.mov
gameplay/*.m4v
gameplay/*.avi

# Whisper model cache
.cache/

# Loose trending-package JSONs are local QA artifacts. The daily routine
# writes its packages into a date-stamped subdir (state/trending_packages/
# YYYYMMDD/) which is what we want to track.
state/trending_packages/*.json

# Per-machine entity media resolution cache. Regenerated on demand.
state/entity_media_cache.json

# OAuth secrets — never commit
client_secret.json
token.json
# Any other YouTube tokens we mint during channel setup (token_new.json,
# per-channel files, etc.). Tokens carry refresh credentials so the
# pattern is broad on purpose.
token*.json
kokoro_models/
.tiktok_secret
.tiktok_redirect_uri
data_learning/music/

# media_funnel runtime state — quota counters reset daily, cache is
# regenerated on demand. Tracking these would create churn-y commits
# without operational value.
state/news_image_cache.json
state/news_image_quota.json
state/last_failed_audit.json
# hook_media downloads subject photos here on demand; binary blobs, regenerated
# in CI — gitignore so they don't bloat the repo or create churn.
state/hook_images/
state/scene_images/
preview/
